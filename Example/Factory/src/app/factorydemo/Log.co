module app.factorydemo;

import std.io::{println};

public class Log() {
    public static func info(string message) :> void {
        println("[info] " + message);
    }

    public static func warn(string message) :> void {
        println("[warn] " + message);
    }

    public static func line() :> void {
        println("----------------------------------------");
    }
}
